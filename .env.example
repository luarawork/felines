# Copy this file to .env.local and fill in real values. Never commit
# .env.local — it's already covered by .gitignore's `.env*` rule.

# Supabase project URL. Public by design (safe to ship in the client bundle).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public API key. Public by design — RLS policies are
# what actually protect data, not keeping this key secret.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenWeatherMap API key, used client-side for the extreme-weather
# caretaker alert feature. Public by design (embedded in the browser bundle).
NEXT_PUBLIC_WEATHER_API_KEY=your-openweathermap-api-key

# Base URL used to build absolute links (e.g. in emails/shared links).
# Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
